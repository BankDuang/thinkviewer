# Python
__pycache__/
*.py[cod]
*$py.class
.env
thinkviewer.db

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Local uploads and screenshots
uploads/
*.png
# Allow screenshots folder
!screenshots/
!screenshots/*.png

# Built-in macOS wallpaper assets (override *.png above)
!static/wallpapers/
!static/wallpapers/*.png

# Brand assets (logo) — override *.png above
!static/brand/
!static/brand/*.png

# Runtime logs (managed-server output, deploy logs, server run output)
server_logs/
*.log

# Runtime uploads (Client Project / CRM attachments + files) — user data, not code
client_project_files/
notes_files/

# Committed frontend build artifact (so the auto-updater always ships a working bundle)
!frontend/dist/
!frontend/dist/**

# Frontend local env (never commit secrets to the client)
frontend/.env
frontend/.env.*
